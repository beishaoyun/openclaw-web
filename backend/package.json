    "ioredis": "^5.3.2",
    "pino": "^8.18.0",
    "pino-pretty": "^10.3.1",
    "postgres": "^3.4.3",
    "ssh2": "^1.17.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
